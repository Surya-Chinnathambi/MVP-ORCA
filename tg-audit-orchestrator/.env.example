# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default / dev):
DATABASE_URL=sqlite:///data/app.db
# Postgres (production):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/tg_audit

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-32-char-minimum

# ── Admin seed account (Stage 1 seed script) ─────────────────────────────────
ADMIN_EMAIL=admin@techguard.local
ADMIN_PASSWORD=changeme

# ── AI — Anthropic Claude ────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...

# ── Telegram bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...

# ── Background workers (Phase 2) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Encryption at rest (Stage 21) ────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── SSO / OIDC (Stage 21, disabled by default) ───────────────────────────────
SSO_ENABLED=false
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_TENANT_ID=

# ── Operations (Stage 29) ─────────────────────────────────────────────────────
# Environment profile: dev | test | prod
APP_ENV=dev
# Where to store backup archives
BACKUP_DIR=data/backups
# Audit log retention in days (events older than this are pruned)
AUDIT_RETENTION_DAYS=365

# ── Optional flags ────────────────────────────────────────────────────────────
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default / dev):
DATABASE_URL=sqlite:///data/app.db
# Postgres (production):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/tg_audit

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-32-char-minimum

# ── Admin seed account (Stage 1 seed script) ─────────────────────────────────
ADMIN_EMAIL=admin@techguard.local
ADMIN_PASSWORD=changeme

# ── AI — Anthropic Claude ────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...

# ── Telegram bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...

# ── Background workers (Phase 2) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Optional flags ────────────────────────────────────────────────────────────
DEBUG=false
